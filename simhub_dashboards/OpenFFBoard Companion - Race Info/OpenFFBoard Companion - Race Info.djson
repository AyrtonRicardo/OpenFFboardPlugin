                      "Formula": {
                        "JSExt": 0,
                        "Interpreter": 1,
                        "Expression": "var d = $prop('DeltaToSessionBest');\nif (d == null) return '--';\nreturn (d >= 0 ? '+' : '') + d.toFixed(2);"
                      },

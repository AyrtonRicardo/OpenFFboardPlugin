                        "JSExt": 0,
                        "Interpreter": 1,
                        "Expression": "if ($prop('Flag_Black')) return 'BLACK';\nif ($prop('Flag_Checkered')) return 'FINISH';\nif ($prop('Flag_Blue')) return 'BLUE';\nif ($prop('Flag_Yellow')) return 'YELLOW';\nif ($prop('Flag_White')) return 'WHITE';\nif ($prop('Flag_Green')) return 'TRACK CLEAR';\nreturn 'CLEAR';"
                      },

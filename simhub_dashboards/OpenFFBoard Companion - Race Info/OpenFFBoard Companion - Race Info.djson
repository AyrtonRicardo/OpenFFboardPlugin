                    },
                    "TextColor": {
                      "Formula": {
                        "JSExt": 0,
                        "Interpreter": 1,
                        "Expression": "var d = $prop('DeltaToSessionBest');\nif (d == null) return '#FF8A8A98';\nif (d < -0.001) return '#FF4CAF50';\nif (d > 0.001) return '#FFE53935';\nreturn '#FFFFFFFF';"

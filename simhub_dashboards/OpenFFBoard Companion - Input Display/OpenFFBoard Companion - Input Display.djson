{
  "Variables": {
    "DashboardVariables": [
      {
        "VariableName": "SteeringAngleDeg",
        "EvaluateOnlyOnce": false,
        "OverrideWithParentDashboardVariableWhenAvailable": true,
        "ValueExpression": {
          "JSExt": 0,
          "Interpreter": 1,
          "Expression": "var range = $prop('OpenFFBoardPlugin.InputDisplay.SteeringRotationDegrees');\nif (range == null || range <= 0) range = 480;\nvar rad = $prop('GameRawData.Telemetry.SteeringWheelAngle');\nif (rad != null) return -rad * (180 / Math.PI);\nvar n = $prop('GameRawData.Physics.SteerAngle');\nif (n != null) return n * (range / 2);\nreturn 0;"
        },
        "EvaluateBeforeScreenRoles": false
      }
    ]
  },
  "Version": 2,
  "Id": "9681a255-b59b-47af-88e3-e876057d0b9d",

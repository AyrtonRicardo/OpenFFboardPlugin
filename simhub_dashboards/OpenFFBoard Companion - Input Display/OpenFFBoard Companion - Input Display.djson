                          "Width": 15.0,
                          "Name": "Shift Light",
                          "RenderingSkip": 0,
                          "MinimumRefreshIntervalMS": 0.0,
                          "IsToggleImage": true,
                          "Value": false,
                          "ShiftLightMode": 1,
                          "LedNumber": 1,
                          "TotalLeds": 6,
                          "RedlineBlink": true,
                          "RedlineBlinkDelay": 250,
                          "PitlimiterBlinkDelay": 250,
                          "PitlimiterBlink": true,
                          "OnImage": "library:Leds\\Set3\\Green.png",
                          "OffImage": "library:Leds\\Set3\\LED Off.png",
                          "StackImagesWhenOn": true,
                          "AutoSize": false,
                          "Bindings": {
                            "LedNumber": {
                              "Formula": {
                                "JSExt": 0,
                                "Interpreter": 1,
                                "Expression": "return repeatindex()"
                              },
                              "Mode": 2
                            },
                            "OnImage": {
                              "Formula": {
                                "JSExt": 0,
                                "Interpreter": 1,
                                "Expression": "const index = repeatindex();\nif (index < 5) return 'library:Leds\\\\Set3\\\\Green.png';\nreturn 'library:Leds\\\\Set3\\\\Red.png';"
                              },
                              "Mode": 2
                            },
                            "Value": {
                              "Formula": {
                                "JSExt": 0,
                                "Interpreter": 1,
                                "Expression": "var t = $prop('OpenFFBoardPlugin.InputDisplay.ShiftLightThresholdPercent');\nif (t == null || t <= 0 || t >= 100) t = 85;\nvar rpm = $prop('DataCorePlugin.GameData.Rpms');\nvar max = $prop('DataCorePlugin.GameData.MaxRpm');\nif (max == null || max <= 0) return false;\nvar pct = rpm / max * 100;\nvar i = repeatindex();\nvar step = (100 - t) / 6;\nreturn pct >= t + (i - 1) * step;"
                              },
                              "Mode": 2
                            }
                          }
                        }
                      ],
                      "Visible": true,
                      "BlinkPhasisInverted": false,
                      "Name": "Shift Light Repeat",
                      "RenderingSkip": 0,
                      "MinimumRefreshIntervalMS": 0.0
                    }
                  ]

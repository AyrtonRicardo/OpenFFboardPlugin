                      "Formula": {
                        "JSExt": 0,
                        "Interpreter": 1,
                        "Expression": "var m = $prop('OpenFFBoardPlugin.InputDisplay.CornerMinSpeedKmh');\nif (m == null || m < 0) return '--';\nconst unit = $prop('SpeedLocalUnit');\nreturn '' + Math.round((unit == 'KMH') ? m : m * 0.621371);"
                      },
                      "Mode": 2
                    },
                    "TextColor": {
                      "Formula": {
                        "JSExt": 0,
                        "Interpreter": 1,
                        "Expression": "var m = $prop('OpenFFBoardPlugin.InputDisplay.CornerMinSpeedKmh');\nif (m == null || m < 0) return '#FF8A8A98';\nreturn (Math.abs($prop('SpeedKmh') - m) < 3) ? '#FFFFD600' : '#FFFFFFFF';"
                      },
                      "Mode": 2
                    }
                  }

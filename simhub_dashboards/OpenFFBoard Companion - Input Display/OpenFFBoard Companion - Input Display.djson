                {
                  "$type": "SimHub.Plugins.OutputPlugins.GraphicalDash.Models.ChartItem, SimHub.Plugins",
                  "BackgroundColor": "#00FFFFFF",
                  "Height": 112.0,
                  "Left": 10.0,
                  "Top": 8.0,
                  "Visible": true,
                  "BlinkPhasisInverted": false,
                  "Width": 500.0,
                  "Name": "Steering Trace",
                  "RenderingSkip": 0,
                  "MinimumRefreshIntervalMS": 0.0,
                  "ChartSuspended": false,
                  "ChartEnabled": true,
                  "CurrentValue": 0.0,
                  "Minimum": -6.0,
                  "UseMinimum": true,
                  "UseMaximum": true,
                  "LineColor": "#66FFFFFF",
                  "LineTickness": 2,
                  "Maximum": 101.0,
                  "PointsCount": 400.0,
                  "Bindings": {
                    "CurrentValue": {
                      "Formula": {
                        "JSExt": 0,
                        "Interpreter": 1,
                        "Expression": "const deg = isnull($prop('variable.SteeringAngleDeg'), 0);\nconst clamped = Math.max(-90, Math.min(90, deg));\nreturn 50 - (clamped / 90) * 50;"
                      },
                      "Mode": 2
                    }
                  }
                },
                {
                  "$type": "SimHub.Plugins.OutputPlugins.GraphicalDash.Models.ChartItem, SimHub.Plugins",

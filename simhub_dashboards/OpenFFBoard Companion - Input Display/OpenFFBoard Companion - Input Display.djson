                        "Expression": "var b = $prop('Brake');\nvar abs = $prop('ABSActive');\nvar hold = abs;\ntry {\n  var now = new Date().getTime();\n  if (abs) root['absHold'] = now;\n  hold = (now - (root['absHold'] || 0)) < 250;\n} catch(e) { hold = abs; }\nreturn hold ? b - 3.4 : b;"

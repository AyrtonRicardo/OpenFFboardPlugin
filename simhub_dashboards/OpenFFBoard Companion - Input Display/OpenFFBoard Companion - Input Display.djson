                      "Childrens": [
                        {
                          "$type": "SimHub.Plugins.OutputPlugins.GraphicalDash.Models.ShiftLightItem, SimHub.Plugins",
                          "BackgroundColor": "#00FFFFFF",
                          "Height": 15.0,
                          "Left": 0.0,

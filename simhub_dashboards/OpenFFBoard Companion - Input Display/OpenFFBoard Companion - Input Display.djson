                  "Visible": true,
                  "BlinkPhasisInverted": false,
                  "Width": 500.0,
                  "Name": "Throttle TC Trace",
                  "RenderingSkip": 0,
                  "MinimumRefreshIntervalMS": 0.0,
                  "ChartSuspended": false,
                  "ChartEnabled": true,
                  "CurrentValue": 0.0,
                  "Minimum": -6.0,
                  "UseMinimum": true,
                  "UseMaximum": true,
                  "LineColor": "#FFE040FB",
                  "LineTickness": 3,
                  "Maximum": 101.0,
                  "PointsCount": 400.0,
                  "Bindings": {
                    "CurrentValue": {
                      "Formula": {
                        "JSExt": 1,
                        "Interpreter": 1,
                        "Expression": "var t = $prop('Throttle');\nvar tcs = $prop('TCActive');\nvar hold = tcs;\ntry {\n  var now = new Date().getTime();\n  if (tcs) root['tcHold'] = now;\n  hold = (now - (root['tcHold'] || 0)) < 250;\n} catch(e) { hold = tcs; }\nreturn hold ? t - 3.4 : t;"
                      },
                      "Mode": 2
                    }
                  }
                },
                {
                  "$type": "SimHub.Plugins.OutputPlugins.GraphicalDash.Models.ChartItem, SimHub.Plugins",

<UserControl x:Class="OpenFFBoardPlugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,12,16">

            <styles:SHSection Title="OpenFFBoard Companion" ShowSeparator="True">
                <StackPanel>

                    <!-- ═══ CONNECTION ═══════════════════════════════════════════════ -->
                    <styles:SHSubSection Title="Connection">
                        <StackPanel>

                            <!-- Status row: indicator dot · board name · action buttons -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0"
                                         x:Name="ViewConnectionDot"
                                         Width="10" Height="10"
                                         Fill="#888888"
                                         VerticalAlignment="Center" />

                                <TextBlock Grid.Column="1"
                                           x:Name="ViewConnectedTo"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           Text="Not connected"
                                           FontStyle="Italic"
                                           Opacity="0.6" />

                                <styles:SHButtonPrimary Grid.Column="2"
                                                        Click="ViewSelectedCom_Connect"
                                                        Margin="0,0,6,0"
                                                        VerticalAlignment="Center">
                                    Connect
                                </styles:SHButtonPrimary>

                                <styles:SHButtonSecondary Grid.Column="3"
                                                          Click="ViewSelectedCom_Disconnect"
                                                          VerticalAlignment="Center">
                                    Disconnect
                                </styles:SHButtonSecondary>
                            </Grid>

                            <!-- Available boards list -->
                            <TextBlock Text="Available devices"
                                       Margin="0,12,0,4"
                                       Opacity="0.55"
                                       FontSize="11" />

                            <ListBox x:Name="viewBoards"
                                     Loaded="ViewBoards_Loaded"
                                     SelectionChanged="ViewBoards_SelectionChanged"
                                     HorizontalContentAlignment="Stretch"
                                     MaxHeight="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8"
                                                         Fill="#4CAF50"
                                                         Margin="0,0,4,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="connected"
                                                           Foreground="#4CAF50"
                                                           FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <styles:SHToggleCheckbox x:Name="ViewAutoConnectOnStartup"
                                                     Margin="0,10,0,0"
                                                     Checked="ViewAutoConnectOnStartup_Checked"
                                                     Unchecked="ViewAutoConnectOnStartup_Unchecked">
                                Auto-connect on startup
                            </styles:SHToggleCheckbox>

                            <!-- Inline error message (hidden when empty) -->
                            <TextBlock x:Name="ViewLastError"
                                       Foreground="#E53935"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"
                                       Visibility="Collapsed" />

                        </StackPanel>
                    </styles:SHSubSection>

                    <styles:SHSectionSeparator />

                    <!-- ═══ PROFILE MANAGEMENT ════════════════════════════════════════ -->
                    <styles:SHSubSection Title="Profile Management">
                        <StackPanel>

                            <!-- Current state info: game + active profile -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Current game:"
                                           Opacity="0.55"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           x:Name="ViewCurrentGame"
                                           Text="—"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Active profile:"
                                           Opacity="0.55"
                                           VerticalAlignment="Center"
                                           Margin="0,6,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           x:Name="ViewCurrentActiveProfile"
                                           Text="—"
                                           VerticalAlignment="Center"
                                           Margin="0,6,0,0" />
                            </Grid>

                            <!-- Profile action buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <styles:SHButtonPrimary Click="CreateProfileForCurrentGame_Click">
                                    Create profile for current game
                                </styles:SHButtonPrimary>
                                <styles:SHButtonSecondary Margin="8,0,0,0"
                                                          Click="ApplyCurrentProfile_Click">
                                    Apply profile to board
                                </styles:SHButtonSecondary>
                            </StackPanel>

                            <styles:SHSectionSeparator />

                            <!-- Profiles JSON file path -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Profiles file:"
                                           Opacity="0.55"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           x:Name="ViewProfileJsonPath"
                                           Text="Not configured"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                                <styles:SHButtonSecondary Grid.Column="2"
                                                          Margin="8,0,0,0"
                                                          Click="SelectProfileJsonPath_Click">
                                    Browse…
                                </styles:SHButtonSecondary>
                            </Grid>

                            <TextBlock x:Name="ViewProfileCount"
                                       Opacity="0.5"
                                       FontSize="11"
                                       Margin="110,3,0,0" />

                        </StackPanel>
                    </styles:SHSubSection>

                    <styles:SHSectionSeparator />

                    <!-- ═══ PLUGIN SETTINGS ══════════════════════════════════════════ -->
                    <styles:SHSubSection Title="Plugin Settings">
                        <StackPanel>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Settings file:"
                                           Opacity="0.55"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           x:Name="ViewPluginConfigJsonPath"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                            </Grid>

                            <styles:SHButtonPrimary HorizontalAlignment="Left"
                                                    Margin="0,10,0,0"
                                                    Click="SaveConfiguration_Click">
                                Save settings
                            </styles:SHButtonPrimary>

                        </StackPanel>
                    </styles:SHSubSection>

                </StackPanel>
            </styles:SHSection>

        </StackPanel>
    </ScrollViewer>
</UserControl>
